rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- シフト提出データ ----
    // ・誰でも読み取り可能（スタッフが自分の提出内容を再読込するため）
    // ・誰でも作成・上書き可能（スタッフが提出するため）
    // ・削除は禁止（データ保護）
    // ・1ドキュメントは 100KB 以下に制限
    match /shifts/{docId} {
      allow read:   if true;
      allow create: if validShift(request.resource.data);
      allow update: if validShift(request.resource.data);
      allow delete: if false;
    }

    // ---- 休業日設定 ----
    match /closedDays/{yearMonth} {
      allow read:  if true;
      allow write: if request.resource.data.keys().hasOnly(['days'])
                   && request.resource.data.days is list;
    }

    // ---- アプリ設定（PINなど） ----
    // ・PINの読み取りは全員可能（照合のため）
    // ・書き込みは全員可能（認証はクライアント側のPIN照合で担保）
    match /settings/{docId} {
      allow read, write: if true;
    }

    // シフトデータのバリデーション関数
    function validShift(data) {
      return data.keys().hasAll(['name', 'targetMonth', 'targetHalf', 'shiftType'])
        && data.name       is string && data.name.size()        > 0 && data.name.size()        <= 50
        && data.targetMonth is string && data.targetMonth.matches('\\d{4}-\\d{2}')
        && data.targetHalf  in ['first', 'second']
        && data.shiftType   in ['all', 'specific'];
    }
  }
}
